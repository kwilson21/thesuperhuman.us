---
import '~/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'profile' | 'article';
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = '/og-image.png',
  ogImageAlt = 'The Superhuman Group LLC',
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

function jsonLdString(data: object): string {
  return JSON.stringify(data)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/\//g, '\\u002f');
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="The Superhuman Group" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="author" content="Kazon Wilson" />
    <link rel="me" href="https://github.com/kwilson21" />
    <link rel="me" href="https://www.linkedin.com/in/kazonwilson/" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && (
      <script type="application/ld+json" set:html={jsonLdString(jsonLd)} />
    )}
  </head>
  <body class="bg-paper text-ink font-serif">
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

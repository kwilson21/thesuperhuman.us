---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Footer from '~/components/Footer.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }));
}

type Props = { note: CollectionEntry<'notes'> };
const { note } = Astro.props as Props;
const { Content } = await note.render();

const canonical = new URL(`/notes/${note.slug}`, Astro.site).toString();
const datePublished = note.data.date.toISOString();
const dateModified = (note.data.updated ?? note.data.date).toISOString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: note.data.title,
  description: note.data.description ?? note.data.title,
  datePublished,
  dateModified,
  author: { '@id': 'https://thesuperhuman.us/#kazon' },
  publisher: { '@id': 'https://thesuperhuman.us/#org' },
  inLanguage: 'en-US',
  mainEntityOfPage: canonical,
  url: canonical,
  keywords: note.data.tags.join(', ') || undefined,
  image: note.data.ogImage
    ? new URL(note.data.ogImage, Astro.site).toString()
    : 'https://thesuperhuman.us/og-image.png',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://thesuperhuman.us/' },
      { '@type': 'ListItem', position: 2, name: 'Notes', item: 'https://thesuperhuman.us/notes' },
      { '@type': 'ListItem', position: 3, name: note.data.title, item: canonical },
    ],
  },
};

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={`${note.data.title} · Kazon Wilson`}
  description={note.data.description ?? note.data.title}
  ogType="article"
  ogImage={note.data.ogImage ?? '/og-image.png'}
  ogImageAlt={note.data.title}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-content px-6 py-16 md:py-24">
    <header class="mb-10">
      <p class="eyebrow mb-3">
        <a href="/notes" style="border-bottom: none; color: var(--muted);">Notes</a>
        <span class="mx-1.5">·</span>
        <time datetime={datePublished}>{dateFormatter.format(note.data.date)}</time>
        {note.data.updated && note.data.updated.valueOf() !== note.data.date.valueOf() && (
          <>
            <span class="mx-1.5">·</span>
            <span>Updated <time datetime={dateModified}>{dateFormatter.format(note.data.updated)}</time></span>
          </>
        )}
      </p>
      <h1 class="display mb-3">{note.data.title}</h1>
      {note.data.description && (
        <p class="lede max-w-measure text-muted">{note.data.description}</p>
      )}
    </header>

    <div class="prose-editorial">
      <Content />
    </div>

    {note.data.tags.length > 0 && (
      <footer class="mt-16 pt-8 border-t border-rule">
        <p class="eyebrow mb-2">Tags</p>
        <p class="font-mono text-xs text-muted">{note.data.tags.join(' · ')}</p>
      </footer>
    )}
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style is:global>
  .prose-editorial { font-family: theme('fontFamily.serif'); color: var(--ink); }
  .prose-editorial > * + * { margin-top: 1.5em; }
  .prose-editorial h2 { font-size: 1.75rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--rule); }
  .prose-editorial h3 { font-size: 1.25rem; margin-top: 2rem; font-weight: 500; }
  .prose-editorial p { font-size: 1.0625rem; line-height: 1.65; max-width: 38rem; }
  .prose-editorial p em { font-style: italic; }
  .prose-editorial strong { font-weight: 600; }
  .prose-editorial hr { border: 0; border-top: 1px solid var(--rule); margin: 3rem 0; max-width: 38rem; }
  .prose-editorial ul, .prose-editorial ol { padding-left: 1.25rem; max-width: 38rem; }
  .prose-editorial li { font-size: 1.0625rem; line-height: 1.65; }
  .prose-editorial a { border-bottom: 1px solid var(--accent); }
  .prose-editorial code {
    font-family: theme('fontFamily.mono');
    font-size: 0.9em;
    background: rgba(174, 85, 52, 0.08);
    padding: 1px 4px;
    border-radius: 2px;
  }
  .prose-editorial pre {
    font-family: theme('fontFamily.mono');
    font-size: 0.875rem;
    line-height: 1.55;
    background: #111;
    color: #f5f1e8;
    padding: 1rem 1.25rem;
    border-radius: 4px;
    overflow-x: auto;
    max-width: 38rem;
  }
  .prose-editorial pre code { background: transparent; padding: 0; color: inherit; }
  .prose-editorial blockquote {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    color: var(--muted);
    font-style: italic;
    max-width: 38rem;
  }
</style>

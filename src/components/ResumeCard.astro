---
interface Props {
  title: string;
  audience: string;
  description: string;
  audienceKey: 'general' | 'leadership' | 'dod';
}
const { title, audience, description, audienceKey } = Astro.props;
---
<a
  href={`#resume-request-form`}
  data-audience={audienceKey}
  class="resume-card block border border-rule bg-paper p-6 rounded-sm hover:border-accent transition-colors"
  style="border-bottom: 1px solid var(--rule);"
>
  <div class="eyebrow mb-3">{audience}</div>
  <h3 class="font-serif font-medium text-xl mb-2">{title}</h3>
  <p class="text-sm text-muted leading-relaxed mb-4">{description}</p>
  <span class="font-sans text-xs font-medium text-accent">
    Request this resume →
  </span>
</a>

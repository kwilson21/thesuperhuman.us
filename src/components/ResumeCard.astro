---
interface Props {
  title: string;
  audience: string;
  description: string;
  audienceKey: 'general' | 'dod';
}
const { title, audience, description, audienceKey } = Astro.props;
---
<a
  href={`#resume-request-form`}
  data-audience={audienceKey}
  class="resume-card block md:grid md:grid-rows-subgrid md:row-span-4 border border-rule bg-paper p-6 rounded-sm transition-colors"
>
  <div class="eyebrow mb-3 md:mb-0">{audience}</div>
  <h3 class="font-serif font-medium text-xl mb-2 md:mb-0">{title}</h3>
  <p class="text-sm text-muted leading-relaxed mb-4 md:mb-0">{description}</p>
  <span class="font-sans text-xs font-medium text-accent">
    Request this resume →
  </span>
</a>

<style is:global>
  /* Cancel the global `a { border-bottom: 1px solid var(--accent) }` underline
     on the resume cards so the four-side border looks consistent at rest, and
     so :hover lights up the entire frame (not just three sides). */
  a.resume-card { border-bottom-color: var(--rule); }
  a.resume-card:hover { border-color: var(--accent); }
</style>
